@* ═══════════════════════════════════════════════════════════════
    DebugPanel — Sidebar-Modul: Dummy zum Testen des Panel-Systems.
    
    Eingeklappt: Kurzform der AggregateId.
    Ausgeklappt: Volle ID + PairKey + Zeitstempel + Status.
═══════════════════════════════════════════════════════════════ *@

@if (IsExpanded)
{
    <div style="padding: 12px; font-size: 12px; color: #999;">
        @if (Entry != null)
        {
            <div style="margin-bottom: 12px;">
                <div style="color: #666; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Aggregate ID</div>
                <div style="font-family: monospace; color: #ccc; word-break: break-all; font-size: 11px;">@Entry.Id</div>
            </div>
            <div style="margin-bottom: 12px;">
                <div style="color: #666; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">PairKey</div>
                <div style="font-family: monospace; color: #ccc;">@(Entry.PairKey ?? "—")</div>
            </div>
            <div style="margin-bottom: 12px;">
                <div style="color: #666; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Produziert</div>
                <div style="color: #ccc;">@Entry.ProduziertAm.ToString("dd.MM.yyyy HH:mm:ss")</div>
            </div>
            <div style="margin-bottom: 12px;">
                <div style="color: #666; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Status</div>
                <div style="color: @(Entry.IstKomplett ? "#4ade80" : "#f0c040");">
                    @(Entry.IstKomplett ? "Komplett" : "Warte auf 2. Bild")
                </div>
            </div>
            <div>
                <div style="color: #666; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Inspiziert</div>
                <div style="color: @(Entry.IstInspiziert ? "#4ade80" : "#f87171");">
                    @(Entry.IstInspiziert ? "Ja" : "Nein")
                </div>
            </div>
        }
        else
        {
            <div style="color: #555;">Kein Paar</div>
        }
    </div>
}
else
{
    <div style="padding: 8px 4px; display: flex; flex-direction: column; align-items: center;">
        @if (Entry != null)
        {
            <span style="font-family: monospace; font-size: 9px; color: #666;
                         writing-mode: vertical-lr; transform: rotate(180deg);">
                @Entry.Id.ToString()[..8]
            </span>
        }
        else
        {
            <span style="color: #444; font-size: 10px;">—</span>
        }
    </div>
}

@code {
    [Parameter] public bool IsExpanded { get; set; }
    [Parameter] public ImagePairEntry? Entry { get; set; }
}