@using Microsoft.AspNetCore.Components.Routing

<MudThemeProvider IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<Router AppAssembly="typeof(App).Assembly">
    <Found Context="r">
        <RouteView RouteData="r" />
    </Found>
    <NotFound>
        <MudText Typo="Typo.h6" Class="pa-4">Seite nicht gefunden.</MudText>
    </NotFound>
</Router>