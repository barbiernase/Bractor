# Host.Grpc Konfiguration
# Wird von systemd als EnvironmentFile geladen

# gRPC
Grpc__Port=5001

# PostgreSQL (EventStore)
ConnectionStrings__EventStore=Host=localhost;Database=cqrs_events;Username=postgres;Password=postgres
EventStore__Schema=es

# Redis (VersionTracker + ReadModel-Deps)
Redis__Endpoint=localhost:6379
Redis__Database=1

# Consul (Proto.Actor Cluster Discovery)
Consul__Address=localhost:8500

# Proto.Actor Cluster
Cluster__Name=cqrs-cluster
Cluster__AdvertisedHost=localhost

# Pipeline
Pipeline__WatchPath=/data/input
Pipeline__PreprocessedPath=/data/preprocessed

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production
