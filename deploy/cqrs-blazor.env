# Host.Blazor Konfiguration
# Wird von systemd als EnvironmentFile geladen

# Blazor Server
Blazor__Urls=http://0.0.0.0:5010

# Verbindung zum gRPC-Server
GrpcServer__Address=http://localhost:5001

# Dateipfade (für File-Endpunkt)
Pipeline__WatchPath=/data/input
Pipeline__PreprocessedPath=/data/preprocessed

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production
